rules_version = '2';

// Watched-state is private to each user. No public reads/writes.
service cloud.firestore {
  match /databases/{database}/documents {
    // User preferences (locale, theme, sort, filters) — private per user.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Watched-state is private to each user. No public reads/writes.
      match /watched/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
